# ── Production (Raspberry Pi) ─────────────────────────────────────────────────
# Copier en .env et remplir

# URL publique de l'API — le navigateur envoie ses requêtes ici.
# Caddy intercepte /api/*, retire le préfixe, et passe au backend FastAPI.
NEXT_PUBLIC_API_URL=https://frambourse.kaalynn.fr/api

# Origines autorisées par le backend CORS (doit inclure l'URL du navigateur)
CORS_ORIGINS=["https://frambourse.kaalynn.fr"]

# (Optionnel) Clé API OpenFIGI — gratuit 25k req/jour
# https://www.openfigi.com/api
OPENFIGI_API_KEY=

# Chemin absolu sur le Pi pour la base SQLite + uploads
DATA_DIR=/opt/frambourse/data

# ── Dev local ─────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
# CORS_ORIGINS=["http://localhost:3000"]
# DATA_DIR=./data
