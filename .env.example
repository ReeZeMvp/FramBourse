# Copy to .env and fill in values

# (Optional) OpenFIGI API key — free tier: 25k req/day
# https://www.openfigi.com/api
OPENFIGI_API_KEY=

# URL the BROWSER uses to reach the backend
# On Raspberry Pi behind NPM: e.g. https://api.frambourse.local
# For local dev: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Host path where SQLite DB + uploads are stored (absolute path on Pi)
DATA_DIR=./data
